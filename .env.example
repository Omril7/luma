# --- database (Supabase) ---
# Pooled (port 6543) for the app; direct (port 5432) for migrations
DATABASE_URL=postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres

# --- app ---
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# --- admin seed user ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# --- payments (stub for now; provider TBD: meshulam | tranzila | payplus) ---
PAYMENT_PROVIDER=stub

# --- storage (Cloudinary primary; local = offline dev fallback) ---
STORAGE_DRIVER=cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
UPLOAD_DIR=./uploads

# --- email (Nodemailer SMTP; stub = log to console in dev) ---
EMAIL_PROVIDER=stub
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=

# --- business / storefront ---
NEXT_PUBLIC_WHATSAPP_NUMBER=972500000000
NEXT_PUBLIC_DEFAULT_LANGUAGE=he
NEXT_PUBLIC_CONTACT_EMAIL=eden.cohen3@gmail.com

# --- delivery distance (OpenRouteService) ---
# Free tier (2,000 req/day, no billing): https://openrouteservice.org
OPENROUTESERVICE_API_KEY=your_openrouteservice_api_key